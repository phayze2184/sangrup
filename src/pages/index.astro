---
import BaseLayout from "../layouts/BaseLayout.astro";
import CircuitDecoration from "../components/CircuitDecoration.astro";
import FeedbackPopup from "../components/FeedbackPopup.astro";
import "../styles/index.css";
import {
  certifications,
  portfolioProjects,
  services,
} from "../data/site";
import { withBase } from "../utils/base";
---

<BaseLayout currentPath="/" title="San Electroterm Grup">
  <main id="main-content" tabindex="-1">
    <section class="hero-section">
      <div class="hero-content">
        <CircuitDecoration />
        <div class="hero-content-left">
          <div class="text-buttons">
            <div class="title-text">
              <h1>
                Instalații <span class="highlight">electrice</span> pentru sisteme sigure și fiabile
              </h1>
              <div class="title-text">
                <p>
                  Proiectăm, realizăm și modernizăm instalații feroviare folosind tehnologii de ultimă generație și expertiză solidă, pentru rețele de transport feroviar mai sigure, mai eficiente și mai performante.
                </p>
              </div>
            </div>
            <a class="button is-primary is-uppercase" href="#contact">
              <span class="button-icon" aria-hidden="true">→</span>
              <span class="button-text-wrap">
                <span class="button-text button-text--top">Cere o ofertă</span>
                <span class="button-text button-text--bottom">Cere o ofertă</span>
              </span>
            </a>
          </div>
        </div>
        <div class="hero-content-right">
          <img
            class="hero-media"
            src={withBase("/assets/hero-rail.webp")}
            alt="Echipă în teren la instalații feroviare"
            loading="eager"
          />
          <div class="hero-kpi">
            <div class="hero-kpi-value">23+</div>
            <div class="hero-kpi-label">ani experiență</div>
          </div>
        </div>
      </div>
    </section>

    <section class="section section-certifications" id="certificari">
      <div class="certifications-wrapper overflow-hidden">
        <a
          class="certifications-marquee"
          href={withBase("/certificari")}
          aria-label="Vezi pagina de certificări și autorizații"
        >
          <div class="marquee-track">
            {Array.from({ length: 3 }).map(() => (
              <div class="marquee-group">
                {certifications.map((item) => (
                  <img class="certifications-logo" src={item.src} alt={item.alt} loading="lazy" />
                ))}
              </div>
            ))}
          </div>
        </a>
      </div>
    </section>

    <section class="section" id="despre">
      <div class="container-padding">
        <div class="despre-wrapper">
          <div class="eyebrow is-uppercase">Despre noi</div>
          <div class="despre-text">
            <div class="despre-left">
              <CircuitDecoration className="despre-left-decoration" />
              <h2>Misiunea noastră</h2>
              <div class="description">
                <p>
                  Să oferim soluții complete de instalații electrice și tehnice de cea mai înaltă calitate, contribuind la <span class="highlight">dezvoltarea infrastructurii naționale</span> și asigurând siguranța și eficiența operațională pentru clienții noștri.
                </p>
                <p>
                  Printr-o abordare integrată de inginerie și execuție, asigurăm respectarea cerințelor tehnice și a standardelor aplicabile, livrând soluții fiabile și durabile, optimizate pentru <span class="highlight">exploatare sigură</span> și eficientă pe termen lung.
                </p>
              </div>
            </div>
            <div class="despre-right">
              <h2>Viziunea noastră</h2>
              <div class="description">
                <p>
                  Urmărim dezvoltarea și implementarea unor sisteme electrice feroviare sigure, fiabile și scalabile, bazate pe expertiză inginerească solidă, <span class="highlight">control riguros al calității</span> și utilizarea tehnologiilor validate în exploatare.
                </p>
                <p>
                  Prin optimizarea soluțiilor tehnice, management eficient al riscurilor și respectarea termenelor contractuale, contribuim la realizarea unor <span class="highlight">infrastructuri durabile</span>, pregătite pentru cerințele operaționale actuale și viitoare ale transportului feroviar.
                </p>
              </div>
            </div>
          </div>
          <a class="button is-secondary is-uppercase" href={withBase("/about")}>
            <span class="button-icon" aria-hidden="true">→</span>
            <span class="button-text-wrap">
              <span class="button-text button-text--top">Despre noi</span>
              <span class="button-text button-text--bottom">Despre noi</span>
            </span>
          </a>
        </div>
      </div>
    </section>

    <section class="section section-services" id="servicii">
      <div class="container-padding">
        <div class="header">
          <CircuitDecoration />
          <div class="eyebrow is-uppercase">Ce oferim</div>
          <div class="title-text">
            <h2>Soluții integrate pentru infrastructura feroviară și civilă</h2>
            <p>
              Oferim soluții tehnice integrate pentru infrastructură feroviară și civilă, de la proiectare până la implementare și mentenanță.
            </p>
          </div>
        </div>
        <div class="services-grid" aria-label="Serviciile noastre">
          {
            services.map((service) => (
              <article class="service-item">
                <div class="service-icon" aria-hidden="true">
                  <img src={service.icon} alt="" />
                </div>
                <h3>{service.title}</h3>
                <p>{service.description}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="section section-portfolio" id="portofoliu">
      <div class="container-padding">
        <div class="header">
          <CircuitDecoration />
          <div class="eyebrow is-uppercase">Portofoliu</div>
          <div class="title-text">
            <h2>Proiecte realizate</h2>
            <p>
              Intervenții complete pentru instalații feroviare, de la modernizări complexe la implementări la cheie, cu rezultate măsurabile.
            </p>
          </div>
          <div class="portfolio-grid">
            {
              portfolioProjects.map((project) => (
                <article class="portfolio-card">
                  <div class="portfolio-media">
                    <picture>
                      {project.image.avif && <source srcset={project.image.avif} type="image/avif" />}
                      {project.image.webp && <source srcset={project.image.webp} type="image/webp" />}
                      <img src={project.image.jpg} alt={project.alt} loading="lazy" />
                    </picture>
                  </div>
                  <div class="portfolio-body">
                    <h4 class="text-white">{project.title}</h4>
                    <div class="portfolio-meta">
                      <span class="portfolio-meta-item">
                        <img class="portfolio-meta-icon" src={withBase("/assets/pin-location-white.svg")} alt="" />
                        {project.location}
                      </span>
                      <span class="portfolio-meta-item">
                        <img class="portfolio-meta-icon" src={withBase("/assets/calendar-white.svg")} alt="" />
                        {project.year}
                      </span>
                    </div>
                  </div>
                </article>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <section class="section section-contact" id="contact">
      <div class="contact-wrapper">
        <div class="map-container">
          <figure class="contact-map">
            <iframe
              title="Harta San Electroterm Grup"
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2861.3820224545757!2d28.59999279318542!3d44.17859524373664!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x40baef8ab31dd2b7%3A0x5cc8e3e23db7fe78!2sSan%20Electroterm%20Grup!5e0!3m2!1sro!2sro!4v1769372783990!5m2!1sro!2sro"
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              allowfullscreen
            ></iframe>
          </figure>
        </div>
        <div class="form-wrapper">
          <div class="header">
            <h2>Contactează-ne</h2>
            <p>
              Discutăm cerințele proiectului tău și livrăm soluții electrice personalizate.
            </p>
          </div>
          <form class="form-block" action={withBase("/contact.php")} method="post" novalidate>
            <div class="form-content">
              <div class="form-inputs">
                <label class="form-field">
                  <span class="form-label">Nume</span>
                  <input class="form-input" type="text" name="name" autocomplete="name" required />
                </label>
                <label class="form-field">
                  <span class="form-label">Telefon</span>
                  <input
                    class="form-input"
                    type="tel"
                    name="phone"
                    autocomplete="tel"
                    inputmode="tel"
                    maxlength="14"
                    required
                  />
                </label>
                <label class="form-field">
                  <span class="form-label">Email</span>
                  <input
                    class="form-input"
                    type="email"
                    name="email"
                    autocomplete="email"
                    pattern="^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$"
                    data-email-message="Te rugăm să introduci o adresă de email validă, care să includă caracterul @."
                    required
                  />
                </label>
                <label class="form-field">
                  <span class="form-label">Mesaj</span>
                  <textarea class="form-input form-textarea" name="message" rows="4" required></textarea>
                </label>
              </div>
              <button class="button is-secondary is-uppercase" type="button" data-contact-submit>
                <span class="button-icon" aria-hidden="true">→</span>
                <span class="button-text-wrap">
                  <span class="button-text button-text--top">Trimite mesajul</span>
                  <span class="button-text button-text--bottom">Trimite mesajul</span>
                </span>
              </button>
            </div>
            <div class="form-messages" hidden>
              <div class="success" hidden>
                <p class="form-message form-message--success" role="status" aria-live="polite">
                  Mesajul a fost trimis cu succes. Revenim cât mai curând.
                </p>
              </div>
              <div class="error" hidden>
                <p class="form-message form-message--error" role="alert">
                  A apărut o eroare la trimitere. Încearcă din nou sau scrie-ne la office@sangrup.ro.
                </p>
              </div>
            </div>
          </form>
        </div>
      </div>
    </section>
  </main>

  <FeedbackPopup />
</BaseLayout>
