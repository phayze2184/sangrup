---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Section from "../../components/Section.astro";
import Container from "../../components/Container.astro";
import SectionHeader from "../../components/SectionHeader.astro";
import { certificationDocuments } from "../../data/site";

const documents = certificationDocuments.en.map((document, index) => ({
  ...document,
  fileName: decodeURIComponent(document.filePath.split("/").pop() ?? `${document.id}.pdf`),
  previewPath: `${document.filePath}#toolbar=0&navpanes=0&scrollbar=1`,
  buttonId: `${document.id}-button`,
  panelId: `${document.id}-panel`,
  isOpen: index === 0,
}));
---

<BaseLayout
  currentPath="/en/certificari"
  title="Certifications | San Electroterm Grup"
  description="Download San Electroterm Grup's official certifications and documents."
>
  <main id="main-content" tabindex="-1">
    <Section class="section-certification-library" aria-labelledby="certificari-library-title">
      <Container>
        <div class="certification-library">
          <SectionHeader eyebrow="Official documents">
            <div class="title-text">
              <h2 id="certificari-library-title">Certifications and authorizations</h2>
              <p>
                Each document can be expanded for preview and downloaded individually
                directly from the list.
              </p>
            </div>
          </SectionHeader>

          <div class="certification-accordion" data-certifications-accordion>
            {
              documents.length > 0 ? (
                documents.map((document) => (
                  <article class:list={["certification-item", document.isOpen && "is-open"]} data-accordion-item>
                    <div class="certification-item__header">
                      <button
                        class="certification-trigger"
                        type="button"
                        id={document.buttonId}
                        aria-expanded={document.isOpen ? "true" : "false"}
                        aria-controls={document.panelId}
                        data-accordion-trigger
                      >
                        <span class="certification-trigger__title">{document.title}</span>
                        <span class="certification-trigger__meta">Preview</span>
                      </button>

                      <a class="certification-download" href={document.filePath} download={document.fileName}>
                        <span>Download</span>
                        <span class="certification-download__format">PDF</span>
                      </a>
                    </div>

                    <div
                      class="certification-panel"
                      id={document.panelId}
                      role="region"
                      aria-labelledby={document.buttonId}
                      hidden={!document.isOpen}
                      data-accordion-panel
                    >
                      <div class="certification-panel__body">
                        <figure class="certification-preview">
                          <iframe
                            src={document.previewPath}
                            title={`Preview ${document.title}`}
                            loading="lazy"
                          ></iframe>
                        </figure>

                        <div class="certification-panel__copy">
                          <p>{document.description}</p>
                          <a
                            class="certification-panel__action"
                            href={document.filePath}
                            download={document.fileName}
                          >
                            Download the PDF document
                          </a>
                        </div>
                      </div>
                    </div>
                  </article>
                ))
              ) : (
                <p>No PDF documents are available at this time.</p>
              )
            }
          </div>
        </div>
      </Container>
    </Section>
  </main>
</BaseLayout>

<style>
  .title-text {
    display: flex;
    flex-direction: column;
    gap: var(--title-text-gap);
  }

  .certification-library {
    display: grid;
    gap: var(--elements-gap);
  }

  .certification-accordion {
    display: grid;
    gap: var(--space-16);
  }

  .certification-item__header {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    gap: var(--space-16);
    padding: clamp(1.25rem, 2vw, 1.75rem);
  }

  .certification-panel__body {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(16rem, 1fr);
    gap: clamp(1.25rem, 3vw, 2.5rem);
    padding: 0 clamp(1.25rem, 2vw, 1.75rem) clamp(1.25rem, 2vw, 1.75rem);
  }

  .certification-panel__copy {
    display: grid;
    align-content: start;
    gap: var(--space-16);
    padding-block-start: var(--space-4);
  }

  .certification-item {
    border: var(--stroke-thin) solid var(--color-border-card); /* 1px */
    border-radius: var(--radius-xl);
    background: var(--color-surface-panel);
    box-shadow: var(--box-shadow);
    overflow: clip;
    transition: border-color 180ms ease, box-shadow 180ms ease, background-color 180ms ease;
  }

  .certification-item.is-open {
    border-color: var(--color-border-strong);
    box-shadow: 0 1.125rem 2.5rem var(--shadow-default-color); /* 18px 40px */
  }

  .certification-trigger {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-16);
    width: 100%;
    padding: 0;
    border: 0;
    background: transparent;
    color: var(--color-text-strong);
    cursor: pointer;
    text-align: left;
  }

  .certification-trigger__title {
    font-family: var(--font-heading);
    font-size: clamp(1rem, 1.4vw, 1.375rem); /* 16px to 22px */
    font-weight: var(--weight-semibold);
    line-height: var(--lh-tight);
    letter-spacing: var(--ls-tight);
  }

  .certification-trigger__meta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-8);
    color: var(--color-text-soft);
    font-family: var(--font-eyebrow);
    font-size: var(--subtext-size);
    letter-spacing: var(--ls-wide);
    text-transform: uppercase;
    white-space: nowrap;
  }

  .certification-trigger__meta::after {
    --_toggle-bg: color-mix(in oklch, var(--color-neutral-900) 6%, transparent);
    content: "+";
    display: inline-grid;
    place-items: center;
    inline-size: 1.5rem; /* 24px */
    block-size: 1.5rem; /* 24px */
    border-radius: 50%;
    background: var(--_toggle-bg);
    color: var(--color-text-strong);
    font-family: var(--font-ui);
    font-size: 1rem; /* 16px */
    font-weight: var(--weight-semibold);
    line-height: 1;
    transition: transform 180ms ease, background-color 180ms ease, color 180ms ease;
  }

  .certification-item.is-open .certification-trigger__meta {
    color: var(--color-text-accent);
  }

  .certification-item.is-open .certification-trigger__meta::after {
    transform: rotate(45deg);
    background: color-mix(in oklch, var(--color-brand-500) 16%, transparent);
    color: var(--color-accent);
  }

  .certification-download,
  .certification-panel__action {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-8);
    min-block-size: 2.75rem; /* 44px */
    padding-inline: var(--space-16);
    border: var(--stroke-thin) solid var(--color-border-strong); /* 1px */
    border-radius: var(--radius-pill);
    background: var(--color-surface);
    color: var(--color-text-strong);
    font-family: var(--font-ui);
    font-size: var(--subtext-size);
    font-weight: var(--weight-semibold);
    line-height: 1;
    white-space: nowrap;
  }

  .certification-download__format {
    color: var(--color-text-soft);
    font-size: 0.75rem; /* 12px */
    letter-spacing: var(--ls-wide);
  }

  .certification-download:hover,
  .certification-download:focus-visible,
  .certification-panel__action:hover,
  .certification-panel__action:focus-visible {
    border-color: var(--color-accent);
    background: color-mix(in oklch, var(--color-brand-100) 62%, var(--color-surface));
    color: var(--color-text-strong);
  }

  .certification-panel {
    border-top: var(--stroke-thin) solid var(--color-border-card); /* 1px */
  }

  .certification-preview {
    --_preview-inset-highlight: color-mix(in oklch, var(--color-neutral-0) 60%, transparent);
    margin: 0;
    overflow: clip;
    border: var(--stroke-thin) solid var(--color-border-card); /* 1px */
    border-radius: var(--radius-lg);
    background: var(--color-surface);
    box-shadow: inset 0 0 0 var(--stroke-thin) var(--_preview-inset-highlight);
  }

  .certification-preview iframe {
    display: block;
    width: 100%;
    min-height: clamp(22rem, 48vw, 34rem);
    border: 0;
    background: var(--color-surface);
  }

  .certification-panel__copy p {
    color: var(--color-text-muted);
  }

  @media screen and (max-width: 61.9375rem) { /* 991px */
    .certification-panel__body {
      grid-template-columns: 1fr;
    }
  }

  @media screen and (max-width: 47.9375rem) { /* 767px */
    .certification-item__header {
      grid-template-columns: 1fr;
      align-items: stretch;
    }
  }
</style>

<script>
  const accordions = document.querySelectorAll("[data-certifications-accordion]");

  const syncAccordionItem = (item: Element, expanded: boolean) => {
    const trigger = item.querySelector("[data-accordion-trigger]");
    const panel = item.querySelector("[data-accordion-panel]");

    if (!(trigger instanceof HTMLButtonElement) || !(panel instanceof HTMLElement)) {
      return;
    }

    trigger.setAttribute("aria-expanded", expanded ? "true" : "false");
    panel.hidden = !expanded;
    item.classList.toggle("is-open", expanded);
  };

  accordions.forEach((accordion) => {
    const items = Array.from(accordion.querySelectorAll("[data-accordion-item]"));

    items.forEach((item) => {
      const trigger = item.querySelector("[data-accordion-trigger]");

      if (!(trigger instanceof HTMLButtonElement)) {
        return;
      }

      trigger.addEventListener("click", () => {
        const willExpand = trigger.getAttribute("aria-expanded") !== "true";

        items.forEach((candidate) => {
          syncAccordionItem(candidate, candidate === item ? willExpand : false);
        });
      });
    });
  });
</script>
