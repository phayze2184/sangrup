---
import { Image, getImage } from "astro:assets";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Section from "../../components/Section.astro";
import Container from "../../components/Container.astro";
import SectionHeader from "../../components/SectionHeader.astro";
import Eyebrow from "../../components/Eyebrow.astro";
import CircuitDecoration from "../../components/CircuitDecoration.astro";
import { aboutHistory, managementTeam } from "../../data/site";
import altproSensor from "../../assets/Altpro-numarator-osii-800px.jpg";
import heroImageADesktop from "../../assets/hero-image-a.jpeg";
import heroImageAMobile from "../../assets/hero-image-a-mobile.webp";

const historyCards = aboutHistory.en.map((paragraph, index) => ({
  paragraph,
  classes: ["about-history-card", index === 1 && "about-history-card-center"].filter(Boolean).join(" "),
}));

const teamMembers = managementTeam.map((member) => ({
  ...member,
  alt: `${member.name}, ${member.role}`,
}));

const heroDesktopImage = await getImage({ src: heroImageADesktop, width: 1600 });
const heroMobileImage = await getImage({ src: heroImageAMobile, width: 800 });
const heroDesktop = `url("${heroDesktopImage.src}")`;
const heroMobile = `url("${heroMobileImage.src}")`;
---

<BaseLayout currentPath="/en/about" title="About us | San Electroterm Grup" description="Learn about San Electroterm Grup: our mission, our history, our management team, and our partnerships.">
  <link
    slot="head"
    rel="preload"
    as="image"
    href={heroMobileImage.src}
    media="(max-width: 47.9375rem)"
    fetchpriority="high"
  />
  <link
    slot="head"
    rel="preload"
    as="image"
    href={heroDesktopImage.src}
    media="(min-width: 48rem)"
    fetchpriority="high"
  />
  <main id="main-content" tabindex="-1">
    <div class="hero-section hero-image-a" id="about" aria-labelledby="about-page-title">
      <div class="hero-copy">
        <Eyebrow class="text-white">San Electroterm Grup</Eyebrow>
        <h1 class="hero-title text-white extra-large-text" id="about-page-title">About us</h1>
      </div>
    </div>

    <Section id="istoric" background="about-history" aria-labelledby="history-title">
      <Container>
        <div class="about-history-content">
          <SectionHeader eyebrow="Brief history">
            <h2 id="history-title">Constant evolution</h2>
          </SectionHeader>
          <div class="about-history-grid" aria-label="San Electroterm Grup's evolution">
            {
              historyCards.map((card) => (
                <article class={card.classes}>
                  <CircuitDecoration variant="about-history" />
                  <p set:html={card.paragraph} />
                </article>
              ))
            }
          </div>
        </div>
      </Container>
    </Section>

    <Section id="management" aria-labelledby="management-title">
      <Container>
        <div class="management-wrapper">
          <SectionHeader eyebrow="Management team">
            <h2 id="management-title">Performance-driven management</h2>
          </SectionHeader>
          <div class="management-grid" aria-label="Management team">
            {
              teamMembers.map((member) => (
                <article class="management-card">
                  <Image
                    src={member.image}
                    alt={member.alt}
                    loading="lazy"
                    widths={[150, 250, 350, 500]}
                    sizes="(min-width: 62rem) 25vw, (min-width: 30rem) 33vw, 50vw"
                  />
                  <p class="management-name">{member.name}</p>
                  <p class="management-role">{member.role}</p>
                </article>
              ))
            }
          </div>
        </div>
      </Container>
    </Section>

    <Section id="news" class="section-news" aria-labelledby="news-title">
      <Container>
        <div class="news-wrapper">
          <div class="news-grid">
            <div class="news-left">
              <Eyebrow>Partnerships</Eyebrow>
              <h2 id="news-title">Collaboration and trust</h2>
              <p>
                We work with <span class="highlight">public authorities</span> and <span class="highlight">private companies</span>, delivering tailored solutions that meet the deadlines, budgets, and quality standards of complex infrastructure and installation projects.
              </p>
              <div class="news-image">
                <Image
                  src={altproSensor}
                  alt="Axle-counting sensor mounted on a rail"
                  loading="lazy"
                  widths={[400, 640, 800]}
                  sizes="(min-width: 64rem) 640px, 100vw"
                />
              </div>
            </div>
            <div class="news-right">
              <p>
                San Electroterm Grup SRL is the official representative in Romania of <span class="highlight">Altpro d.o.o.</span>, a manufacturer recognized across Europe for railway traffic safety and control equipment.
              </p>
              <p>
                Through this partnership, San Electroterm Grup provides the supply, integration, and technical support of <span class="highlight">TN-type electronic cabinets</span> <span class="highlight">and axle-counting systems</span>, solutions essential for monitoring and securing modern railway infrastructure.
              </p>
            </div>
          </div>
        </div>
      </Container>
    </Section>
  </main>
</BaseLayout>

<style define:vars={{ heroDesktop, heroMobile }}>
  .hero-image-a {
    --_hero-min-block-size: calc(100dvh - var(--nav-height));
    --_hero-padding-inline: clamp(1rem, 4vw, 2.5rem); /* 16px to 40px */
    --_hero-padding-block-start: clamp(2rem, 8vw, 4.5rem); /* 32px to 72px */
    --_hero-padding-block-end: var(--section-block-lg);
    --_hero-copy-max-width: min(100%, 24rem); /* 384px max */
    --_hero-overlay-top: var(--color-overlay-about-hero-top);
    --_hero-overlay-bottom: var(--color-overlay-about-hero-bottom);
    --_hero-overlay-accent-start: var(--color-overlay-about-hero-accent-start);
    --_hero-overlay-accent-end: var(--color-overlay-about-hero-accent-end);
    --_hero-overlay-glow: var(--color-overlay-about-hero-glow);
    position: relative;
    isolation: isolate;
    display: grid;
    align-items: end;
    justify-items: center;
    overflow: clip;
    min-block-size: var(--_hero-min-block-size);
    padding-inline: var(--_hero-padding-inline);
    padding-block-start: var(--_hero-padding-block-start);
    padding-block-end: var(--_hero-padding-block-end);
    background-image: var(--heroDesktop);
    background-position: center 30%;
    background-repeat: no-repeat;
    background-size: cover;
  }

  .hero-image-a::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 0;
    background:
      linear-gradient(180deg, var(--_hero-overlay-top), var(--_hero-overlay-bottom)),
      linear-gradient(135deg, var(--_hero-overlay-accent-start), var(--_hero-overlay-accent-end)),
      radial-gradient(120% 120% at 12% 88%, var(--_hero-overlay-glow), transparent 20%);
  }

  .hero-image-a > * {
    position: relative;
    z-index: 1;
  }

  .hero-copy {
    display: grid;
    justify-items: center;
    inline-size: fit-content;
    max-inline-size: var(--_hero-copy-max-width);
    gap: var(--space-16);
  }

  .hero-copy :global(.eyebrow) {
    align-self: start;
    justify-self: center;
    border-color: var(--color-border-about-hero-eyebrow);
    background: var(--color-surface-about-hero-eyebrow);
    box-shadow: var(--shadow-about-hero-eyebrow);
    color: var(--color-text-inverse);
    backdrop-filter: blur(0.375rem); /* 6px */
    -webkit-backdrop-filter: blur(0.375rem); /* 6px */
  }

  .hero-title {
    justify-self: center;
    max-width: 10ch;
    margin: 0;
    line-height: 0.94;
    letter-spacing: var(--ls-tight);
    text-align: center;
    text-shadow: var(--shadow-about-hero-title);
    text-wrap: balance;
  }

  .about-history-content {
    --_history-grid-gap: clamp(1.25rem, 2.2vw, 2.125rem); /* 20px to 34px */
    --_history-card-padding-inline: clamp(1.5rem, 2.5vw, 2.625rem); /* 24px to 42px */
    --_history-card-padding-block-start: clamp(6rem, 8vw, 6.25rem); /* 96px to 100px */
    --_history-card-padding-block-end: clamp(1.75rem, 2.8vw, 2.5rem); /* 28px to 40px */
    --_history-card-offset: clamp(5rem, 7vw, 7.5rem); /* 80px to 120px */
    display: grid;
    gap: var(--elements-gap);
    container-type: inline-size;
  }

  .about-history-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.08fr) minmax(0, 0.92fr) minmax(0, 1.08fr);
    align-items: start;
    gap: var(--_history-grid-gap);
  }

  .about-history-card {
    --_history-card-surface: var(--color-surface-card);
    --_history-card-border: var(--color-border-about-history-card);
    --_history-card-shadow: var(--shadow-about-history-card);
    position: relative;
    isolation: isolate;
    display: grid;
    justify-items: start;
    align-content: start;
    gap: clamp(1.5rem, 2.2vw, 2.25rem); /* 24px to 36px */
    overflow: clip;
    padding-inline: var(--_history-card-padding-inline);
    padding-block-start: var(--_history-card-padding-block-start);
    padding-block-end: var(--_history-card-padding-block-end);
    border: var(--stroke-thin) solid var(--_history-card-border); /* 1px */
    border-radius: var(--radius-xl);
    background: var(--_history-card-surface);
    box-shadow: var(--_history-card-shadow);
  }

  .about-history-card-center {
    margin-block-start: var(--_history-card-offset);
  }

  .about-history-card > p {
    position: relative;
    z-index: 1;
    max-width: none;
    margin: 0;
    color: var(--color-text-about-history-card);
    font-size: var(--p-size);
    line-height: var(--lh-body);
    text-wrap: pretty;
  }

  .management-wrapper {
    display: flex;
    flex-direction: column;
    gap: var(--elements-gap);
  }

  .management-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(9.375rem, 1fr)); /* 150px min */
    gap: clamp(1.125rem, 1.8vw, 1.5rem); /* 18px to 24px */
  }

  .management-card {
    --_management-card-border: var(--color-accent);
    --_management-card-surface: var(--color-surface-management-card);
    position: relative;
    aspect-ratio: 1 / 1;
    overflow: clip;
    border: var(--stroke-strong) solid var(--_management-card-border);
    border-radius: var(--radius-lg);
    background: var(--_management-card-surface);
    box-shadow: var(--box-shadow);
  }

  .management-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
  }

  .management-name {
    position: absolute;
    top: -1.25rem; /* -20px */
    right: 1.25rem; /* 20px */
    z-index: 2;
    max-width: calc(100% - 1.5rem); /* minus 24px */
    margin: 0;
    padding: var(--space-4) var(--space-12);
    border-radius: var(--radius-xs);
    background: var(--color-bg);
    color: var(--color-accent);
    font-size: var(--subtext-size);
    font-weight: var(--weight-semibold);
    line-height: 1.2;
    text-align: right;
  }

  .management-role {
    position: absolute;
    right: 0;
    bottom: 0;
    left: 0;
    z-index: 2;
    margin: 0;
    padding: var(--space-8) var(--space-16);
    padding-top: var(--space-16);
    background: var(--color-accent);
    color: var(--color-text-inverse);
    font-size: clamp(0.75rem, 0.85vw, 0.875rem); /* 12px to 14px */
    font-weight: var(--weight-semibold);
    line-height: 1.25;
    text-align: center;
  }

  :global(.section-news .container-padding),
  .news-wrapper,
  .news-left,
  .news-right {
    display: flex;
    flex-direction: column;
  }

  .news-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    align-items: start;
    gap: clamp(2.25rem, 5vw, 6rem); /* 36px to 96px */
  }

  .news-left,
  .news-right {
    align-items: flex-start;
    gap: clamp(1.25rem, 2vw, 1.875rem); /* 20px to 30px */
  }

  .news-right {
    max-width: 60ch;
    padding-block-start: clamp(11.25rem, 22vw, 25rem); /* 180px to 400px */
  }

  .news-left h2 {
    max-width: 12ch;
  }

  .news-image {
    --news-image-bevel: clamp(2rem, 4vw, 4rem); /* 32px to 64px */
    width: min(100%, 40rem); /* 640px max */
    margin-top: clamp(0.875rem, 1.5vw, 1.5rem); /* 14px to 24px */
  }

  .news-image img {
    width: 100%;
    height: auto;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    clip-path: polygon(
      0 0,
      calc(100% - var(--news-image-bevel)) 0,
      100% var(--news-image-bevel),
      100% 100%,
      0 100%
    );
  }

  @media screen and (max-width: 61.9375rem) { /* 991px */
    .news-grid {
      grid-template-columns: 1fr;
    }

    .news-left h2 {
      max-width: none;
    }

    .news-image {
      width: 100%;
    }
  }

  @media screen and (max-width: 47.9375rem) { /* 767px */
    .hero-image-a {
      --_hero-padding-block-end: var(--section-block-md);
      background-image: var(--heroMobile);
      background-position: center;
    }

    .hero-title {
      max-width: 9ch;
    }

    .management-grid {
      grid-template-columns: 1fr;
    }

    .news-right {
      padding-block-start: 0;
    }
  }

  @container (max-width: 60rem) { /* 960px */
    .about-history-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .about-history-card-center {
      margin-block-start: 0;
    }
  }

  @container (max-width: 34rem) { /* 544px */
    .about-history-grid {
      grid-template-columns: 1fr;
    }

    .about-history-card {
      min-block-size: auto;
    }
  }
</style>
