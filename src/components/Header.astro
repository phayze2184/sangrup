---
import { headerNavItems, siteMeta, type HeaderNavItem } from "../data/site";

interface Props {
  currentPath: string;
  homeHref?: string;
  logoSrc?: string;
  logoAlt?: string;
  brandLabel?: string;
  menuId?: string;
  navLabel?: string;
  navigationLinks?: HeaderNavItem[];
}

const base = import.meta.env.BASE_URL;

const {
  currentPath,
  homeHref = base,
  logoSrc = `${base}assets/logo-sangrup.svg`,
  logoAlt = "Sangrup logo",
  brandLabel = "San Grup - Acasă",
  menuId = "menu-button",
  navLabel = "Navigație principală",
  navigationLinks = headerNavItems,
} = Astro.props;

const isHome = currentPath === "/";
const links = navigationLinks.map((link) => ({
  ...link,
  resolvedHref: isHome && link.homeHref ? link.homeHref : link.href,
}));
---

<header class="navbar" id="navbar" role="banner">
  <div class="container-padding nav">
    <a class="brand" href={homeHref} aria-label={brandLabel}>
      <img class="brand-logo" src={logoSrc} alt={logoAlt} />
    </a>
    <nav class="navigation is-uppercase" data-nav aria-label={navLabel}>
      <div class="container-padding">
        {
          links.map((link) => (
            <a class="menu-link" href={link.resolvedHref}>
              {link.label}
            </a>
          ))
        }
      </div>
    </nav>
    <div class="nav-right-side">
      <div class="header-phone-wrapper">
        <img class="icon phone" src={`${base}assets/phone-icon.svg`} alt="" aria-label="Număr de telefon" />
        <a class="link header-phone" href={siteMeta.phoneHref}>
          {siteMeta.phoneDisplay}
        </a>
      </div>
      <input class="menu-button" type="checkbox" id={menuId} aria-label="Deschide meniul" />
      <label class="hamburger-icon" for={menuId} aria-hidden="true">
        <span></span>
        <span></span>
        <span></span>
      </label>
    </div>
  </div>
</header>
