---
import Button from "./Button.astro";
import { getLocale } from "../i18n/locales";
import { ui } from "../i18n/ui";

interface Props {
  className?: string;
  popupTitle?: string;
  actionLabel?: string;
  closeLabel?: string;
  titleId?: string;
  messageId?: string;
  dialogRole?: "alertdialog" | "dialog";
}

const locale = getLocale(Astro.currentLocale);

const {
  className = "",
  popupTitle = ui.feedbackPopup.defaultTitle[locale],
  actionLabel = ui.feedbackPopup.actionLabel[locale],
  closeLabel = ui.feedbackPopup.closeLabel[locale],
  titleId = "feedback-popup-title",
  messageId = "feedback-popup-message",
  dialogRole = "alertdialog",
} = Astro.props;

const popupClasses = ["feedback-popup", className].filter(Boolean).join(" ");
---

<div
  class={popupClasses}
  data-feedback-popup
  data-success-title={ui.feedbackPopup.successTitle[locale]}
  data-error-title={ui.feedbackPopup.errorTitle[locale]}
  hidden
  aria-hidden="true"
>
  <div class="feedback-popup__backdrop" data-feedback-popup-close></div>
  <div
    class="feedback-popup__panel"
    role={dialogRole}
    aria-modal="true"
    aria-labelledby={titleId}
    aria-describedby={messageId}
  >
    <button
      class="feedback-popup__close"
      type="button"
      data-feedback-popup-close
      aria-label={closeLabel}
    >
      ×
    </button>
    <div class="feedback-popup__status" aria-hidden="true"></div>
    <h3 class="feedback-popup__title" id={titleId}>{popupTitle}</h3>
    <p class="feedback-popup__message" id={messageId}></p>
    <Button
      variant="secondary"
      label={actionLabel}
      class="feedback-popup__action"
      data-feedback-popup-close
    />
  </div>
</div>

<script>
  import "../scripts/feedback-popup.js";
</script>

<style>
  .feedback-popup[hidden] {
    display: none;
  }

  .feedback-popup {
    position: fixed;
    inset: 0;
    z-index: 120;
    display: grid;
    place-items: center;
    padding: var(--space-24);
  }

  .feedback-popup__backdrop {
    position: absolute;
    inset: 0;
    background: var(--color-surface-overlay);
    backdrop-filter: blur(0.375rem); /* 6px */
    -webkit-backdrop-filter: blur(0.375rem); /* 6px */
  }

  .feedback-popup__panel {
    position: relative;
    z-index: 1;
    width: min(100%, 32.5rem); /* 520px max */
    padding: clamp(1.5rem, 4vw, 2.25rem); /* 24px to 36px */
    border: var(--stroke-thin) solid var(--color-border-panel); /* 1px */
    border-radius: var(--radius-2xl);
    background: var(--color-surface-panel);
    box-shadow: 0 1.75rem 5rem var(--shadow-panel-color); /* 28px 80px */
  }

  .feedback-popup__close {
    position: absolute;
    top: 0.875rem; /* 14px */
    right: 0.875rem; /* 14px */
    width: 2.5rem; /* 40px */
    height: 2.5rem; /* 40px */
    min-inline-size: 2.75rem; /* 44px */
    min-block-size: 2.75rem; /* 44px */
    border: 0;
    border-radius: var(--radius-pill);
    background: var(--color-surface-overlay-soft);
    color: var(--color-text-strong);
    font-size: 1.75rem; /* 28px */
    line-height: 1;
    cursor: pointer;
  }

  .feedback-popup__status {
    display: grid;
    place-items: center;
    width: 3.5rem; /* 56px */
    height: 3.5rem; /* 56px */
    margin-bottom: var(--space-24);
    border-radius: var(--radius-xl);
    font-size: 1.75rem; /* 28px */
    font-weight: 700;
  }

  .feedback-popup__title {
    margin-bottom: 0.625rem; /* 10px */
    color: var(--color-text-strong);
  }

  .feedback-popup__message {
    margin-bottom: 1.5rem; /* 24px */
    max-width: none;
  }

  .feedback-popup :global(.feedback-popup__action) {
    margin-top: 0;
  }

  .feedback-popup.is-success .feedback-popup__status {
    background: var(--color-success-surface-strong);
    color: var(--color-success);
  }

  .feedback-popup.is-success .feedback-popup__status::before {
    content: "✓";
  }

  .feedback-popup.is-error .feedback-popup__status {
    background: var(--color-error-surface-strong);
    color: var(--color-error);
  }

  .feedback-popup.is-error .feedback-popup__status::before {
    content: "!";
  }

  :global(body.has-feedback-popup) {
    overflow: hidden;
  }

  @media screen and (max-width: 47.9375rem) { /* 767px */
    .feedback-popup {
      padding: var(--space-16);
    }

    .feedback-popup__panel {
      padding: var(--space-24) clamp(var(--space-16), 4vw, var(--space-24));
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .feedback-popup__backdrop {
      backdrop-filter: none;
      -webkit-backdrop-filter: none;
    }
  }

  @media (prefers-contrast: more) {
    .feedback-popup__panel {
      border-width: 0.125rem; /* 2px */
    }

    .feedback-popup__close,
    .feedback-popup__status {
      border: 0.125rem solid currentColor; /* 2px */
    }
  }

  @media (forced-colors: active) {
    .feedback-popup__panel,
    .feedback-popup__close {
      background: Canvas;
      color: CanvasText;
      border: var(--stroke-thin) solid CanvasText; /* 1px */
      box-shadow: none;
    }

    .feedback-popup__backdrop {
      background: transparent;
      backdrop-filter: none;
      -webkit-backdrop-filter: none;
    }

    .feedback-popup__status {
      background: Canvas;
      color: CanvasText;
      border: var(--stroke-thin) solid CanvasText; /* 1px */
    }

    .feedback-popup.is-success .feedback-popup__status,
    .feedback-popup.is-error .feedback-popup__status {
      background: Highlight;
      color: HighlightText;
      border-color: Highlight;
    }
  }
</style>
