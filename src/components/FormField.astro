---
import type { HTMLAttributes } from "astro/types";

interface Props extends HTMLAttributes<"input"> {
  label: string;
  name: string;
  required?: boolean;
  multiline?: boolean;
  rows?: number;
}

const {
  label,
  name,
  type = "text",
  required = false,
  multiline = false,
  rows = 4,
  ...rest
} = Astro.props;
---

<label class="form-field">
  <span class="form-label">{label}</span>
  {multiline ? (
    <textarea class="form-input form-textarea" name={name} rows={rows} required={required} {...rest} />
  ) : (
    <input class="form-input" type={type} name={name} required={required} {...rest} />
  )}
</label>

<style>
  .form-field {
    display: flex;
    flex-flow: column;
    justify-content: flex-start;
    align-items: stretch;
    width: 100%;
    margin-bottom: 0;
    gap: var(--space-8);
  }

  .form-label {
    color: var(--color-text-label);
    font-weight: 600;
  }

  .form-input,
  .form-textarea {
    width: 100%;
    min-block-size: 2.75rem; /* 44px */
    padding: var(--space-12) var(--space-16);
    border: var(--stroke-thin) solid var(--color-border-subtle); /* 1px */
    border-radius: var(--radius-sm);
    background: var(--color-surface);
    box-shadow: inset 0 var(--stroke-thin) 0 var(--color-input-shadow); /* 1px */
    color: var(--color-text-field);
    font-size: 1rem; /* 16px */
  }

  .form-input:focus-visible,
  .form-textarea:focus-visible {
    outline: var(--stroke-focus) solid var(--color-accent);
    outline-offset: 0.125rem; /* 2px */
    border-color: var(--color-accent);
    box-shadow: inset 0 var(--stroke-thin) 0 var(--color-input-shadow), 0 0 0 0.1875rem var(--color-focus-ring); /* 1px, 3px */
  }

  .form-textarea {
    min-height: 8.75rem; /* 140px */
    resize: vertical;
  }

  @media (prefers-contrast: more) {
    .form-input,
    .form-textarea {
      border-width: 0.125rem; /* 2px */
    }
  }

  @media (forced-colors: active) {
    .form-input,
    .form-textarea {
      background: Canvas;
      color: CanvasText;
      border: var(--stroke-thin) solid CanvasText; /* 1px */
      box-shadow: none;
    }
  }
</style>
