---
import "../styles/global.css";
import { getRelativeLocaleUrl } from "astro:i18n";
import Footer from "../sections/Footer.astro";
import Header from "../sections/Header.astro";
import { siteMeta } from "../data/site";
import { withBase } from "../utils/base";
import { getLocale, locales, defaultLocale } from "../i18n/locales";
import { ui } from "../i18n/ui";
import interLatinFont from "../fonts/inter-latin.woff2?url";
import interLatinExtFont from "../fonts/inter-latin-ext.woff2?url";
import spaceGroteskLatinFont from "../fonts/space-grotesk-latin.woff2?url";
import spaceGroteskLatinExtFont from "../fonts/space-grotesk-latin-ext.woff2?url";

interface Props {
  title?: string;
  description?: string;
  currentPath: string;
}

const locale = getLocale(Astro.currentLocale);

const {
  title = siteMeta.title,
  description = siteMeta.description[locale],
  currentPath,
} = Astro.props;

const canonicalPath = currentPath === "/" ? withBase("/") : `${withBase(currentPath).replace(/\/$/, "")}/`;
const canonicalURL = new URL(canonicalPath, Astro.site);

// currentPath already carries any /en prefix (pages pass it explicitly) —
// strip it to get a locale-agnostic slug, then rebuild per locale for hreflang.
const localeAgnosticPath = currentPath.replace(/^\/en(\/|$)/, "/");
const alternateLinks = locales.map((loc) => ({
  hreflang: loc,
  href: new URL(
    getRelativeLocaleUrl(loc, localeAgnosticPath.replace(/^\//, "")),
    Astro.site
  ).toString(),
}));
const xDefaultHref = new URL(
  getRelativeLocaleUrl(defaultLocale, localeAgnosticPath.replace(/^\//, "")),
  Astro.site
).toString();

const ogImageURL = new URL(withBase(`/og/og-image-${locale}.jpg`), Astro.site).toString();
const otherLocale = locale === "ro" ? "en" : "ro";

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: siteMeta.name,
  legalName: siteMeta.companyInfo[0],
  url: new URL("/", Astro.site).toString(),
  logo: new URL(withBase("/assets/logo-sangrup.svg"), Astro.site).toString(),
  description: siteMeta.description[locale],
  telephone: siteMeta.phoneDisplay,
  email: siteMeta.email,
  address: {
    "@type": "PostalAddress",
    streetAddress: siteMeta.addressLines[0],
    postalCode: "900229",
    addressLocality: "Constanța",
    addressCountry: "RO",
  },
  sameAs: [siteMeta.linkedin],
};
---

<!DOCTYPE html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteMeta.name} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={description} />
    <meta property="og:locale" content={locale === "ro" ? "ro_RO" : "en_US"} />
    <meta property="og:locale:alternate" content={otherLocale === "ro" ? "ro_RO" : "en_US"} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <link rel="icon" type="image/svg+xml" href={withBase("/favicon.svg")} />
    <link rel="icon" type="image/png" sizes="32x32" href={withBase("/favicon-32x32.png")} />
    <link rel="icon" type="image/png" sizes="16x16" href={withBase("/favicon-16x16.png")} />
    <link rel="icon" href={withBase("/favicon.ico")} sizes="any" />
    <link rel="apple-touch-icon" href={withBase("/apple-touch-icon.png")} />
    <link rel="canonical" href={canonicalURL} />
    {alternateLinks.map((alt) => (
      <link rel="alternate" hreflang={alt.hreflang} href={alt.href} />
    ))}
    <link rel="alternate" hreflang="x-default" href={xDefaultHref} />
    <script type="application/ld+json" is:inline set:html={JSON.stringify(organizationSchema)} />
    <link rel="preload" as="font" type="font/woff2" href={interLatinFont} crossorigin />
    <link rel="preload" as="font" type="font/woff2" href={interLatinExtFont} crossorigin />
    <link rel="preload" as="font" type="font/woff2" href={spaceGroteskLatinFont} crossorigin />
    <link rel="preload" as="font" type="font/woff2" href={spaceGroteskLatinExtFont} crossorigin />
    <slot name="head" />
  </head>
  <body>
    <a class="skip-link" href="#main-content">{ui.skipLink[locale]}</a>
    <Header currentPath={currentPath} />
    <slot />
    <Footer currentPath={currentPath} />
  </body>
</html>
